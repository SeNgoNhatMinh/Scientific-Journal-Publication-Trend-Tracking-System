# =============================================================================
# Mẫu biến Railway — copy từng khối vào đúng service (Variables → RAW Editor)
# Không dùng dấu " quanh value. AI_SERVICE_URL = domain Railway của service ai-service.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVICE 1: AI  |  Settings → Root Directory = ai-service
# -----------------------------------------------------------------------------
# CORS_ORIGINS=https://scientific-journal-publication-trend-tracking-sy-production.up.railway.app,http://localhost:3000,http://localhost:5000

# -----------------------------------------------------------------------------
# SERVICE 2: BACKEND  |  Settings → Root Directory = backend
# (Chỉ dán sau khi AI có domain + /health OK)
# -----------------------------------------------------------------------------
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/journal_trend?retryWrites=true&w=majority
# JWT_SECRET=your-long-random-secret
# JWT_EXPIRE=7d
# OPENALEX_API_URL=https://api.openalex.org
# OPENALEX_MAILTO=your.email@gmail.com
# EXTERNAL_API_TIMEOUT_MS=90000
# SEMANTIC_SCHOLAR_API_URL=https://api.semanticscholar.org/graph/v1
# SEMANTIC_SCHOLAR_API_KEY=
# CROSSREF_API_URL=https://api.crossref.org
# CROSSREF_MAILTO=your.email@gmail.com
# AI_SERVICE_URL=https://lavish-adventure-production-dd7f.up.railway.app
# CORS_ORIGIN=http://localhost:3000
# PUBLIC_API_URL=https://scientific-journal-publication-trend-tracking-sy-production.up.railway.app
